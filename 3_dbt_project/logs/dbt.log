  create  table "nike_dw"."dbt_dev"."dim_product__dbt_tmp"
  
  
    as
  
  (
    -- models/marts/core/dim_product.sql

with staging as (
    select * from "nike_dw"."dbt_dev"."stg_nike_global"
),

unique_products as (
    -- One row per SKU with the most frequent or descriptive name
    select 
        sku,
        max(product_name) as product_name, -- Taking max to pick one Representative name
        max(category) as category,
        max(subcategory) as subcategory,
        max(gender) as gender
    from staging
    group by 1
),

final as (
    select
        md5(cast(coalesce(cast(sku as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as product_key,
        sku,
        product_name,
        category,
        subcategory,
        gender
    from unique_products
)

select * from final
  );
  
[0m10:15:46.530106 [debug] [Thread-2 (]: On model.nike_project.fct_daily_prices: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "nike_profile", "target_name": "dev", "node_id": "model.nike_project.fct_daily_prices"} */

  
    

  create  table "nike_dw"."dbt_dev"."fct_daily_prices__dbt_tmp"
  
  
    as
  
  (
    -- models/marts/core/fct_daily_prices.sql

with staging as (
    select * from "nike_dw"."dbt_dev"."stg_nike_global"
),

final as (
    select
        md5(cast(coalesce(cast(snapshot_date as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(country_code as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(sku as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_key,
        md5(cast(coalesce(cast(sku as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as product_key,
        md5(cast(coalesce(cast(country_code as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(currency as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as geography_key,
        snapshot_date as date_day,
        price_local,
        sale_price_local,
        effective_price_local,
        -- Metrics
        (price_local - effective_price_local) as discount_amount,
        case 
            when price_local > 0 then (price_local - effective_price_local) / price_local 
            else 0 
        end as discount_percentage_local
    from staging
)

select * from final
  );
  
