  create  table "nike_dw"."dbt_dev"."fct_daily_prices__dbt_tmp"
  
  
    as
  
  (
    -- models/marts/core/fct_daily_prices.sql

with staging as (
    select * from "nike_dw"."dbt_dev"."stg_nike_global"
),

final as (
    select
        md5(cast(coalesce(cast(snapshot_date as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(country_code as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(sku as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as fact_key,
        md5(cast(coalesce(cast(sku as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as product_key,
        md5(cast(coalesce(cast(country_code as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) as geography_key,
        snapshot_date as date_day,
        price_local,
        sale_price_local,
        effective_price_local,
        -- Metrics
        (price_local - effective_price_local) as discount_amount,
        case 
            when price_local > 0 then (price_local - effective_price_local) / price_local 
            else 0 
        end as discount_percentage_local
    from staging
)

select * from final
  );
  
